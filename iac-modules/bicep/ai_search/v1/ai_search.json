{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.45.15.27210",
      "templateHash": "3869424641888762532"
    }
  },
  "parameters": {
    "baseName": {
      "type": "string",
      "metadata": {
        "description": "Short project identifier."
      }
    },
    "environment": {
      "type": "string",
      "metadata": {
        "description": "Environment suffix."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure location."
      }
    },
    "sku": {
      "type": "string",
      "defaultValue": "basic",
      "allowedValues": [
        "free",
        "basic",
        "standard",
        "standard2",
        "standard3",
        "storage_optimized_l1",
        "storage_optimized_l2"
      ],
      "metadata": {
        "description": "Search service SKU."
      }
    },
    "publicNetworkAccessEnabled": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Enable public network access. Combine with allowedIps for the deployer-IP allowlist pattern."
      }
    },
    "allowedIps": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "IPv4 addresses / CIDR ranges allowed on the public endpoint."
      }
    },
    "localAuthenticationEnabled": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Whether admin/query API keys can be used to authenticate. Defaults to false (Entra ID / RBAC only)."
      }
    },
    "subnetId": {
      "type": "string",
      "metadata": {
        "description": "Subnet ID where the PE lives."
      }
    },
    "privateDnsZoneIds": {
      "type": "array",
      "metadata": {
        "description": "Private DNS zone IDs for the searchService PE."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags applied to the search service and PE."
      }
    }
  },
  "variables": {
    "copy": [
      {
        "name": "searchIpRules",
        "count": "[length(parameters('allowedIps'))]",
        "input": {
          "value": "[parameters('allowedIps')[copyIndex('searchIpRules')]]"
        }
      }
    ],
    "searchName": "[toLower(format('srch-{0}-{1}-{2}', parameters('baseName'), parameters('environment'), parameters('location')))]"
  },
  "resources": [
    {
      "type": "Microsoft.Search/searchServices",
      "apiVersion": "2024-06-01-preview",
      "name": "[variables('searchName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "[parameters('sku')]"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": "[union(createObject('replicaCount', 1, 'partitionCount', 1, 'hostingMode', 'default', 'publicNetworkAccess', if(parameters('publicNetworkAccessEnabled'), 'enabled', 'disabled'), 'disableLocalAuth', not(parameters('localAuthenticationEnabled')), 'networkRuleSet', createObject('bypass', 'AzureServices', 'ipRules', variables('searchIpRules'))), if(parameters('localAuthenticationEnabled'), createObject('authOptions', createObject('aadOrApiKey', createObject('aadAuthFailureMode', 'http401WithBearerChallenge'))), createObject()))]"
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[take(format('pe-{0}', variables('searchName')), 64)]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "name": {
            "value": "[format('pe-{0}', variables('searchName'))]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "targetResourceId": {
            "value": "[resourceId('Microsoft.Search/searchServices', variables('searchName'))]"
          },
          "subresourceNames": {
            "value": [
              "searchService"
            ]
          },
          "subnetId": {
            "value": "[parameters('subnetId')]"
          },
          "privateDnsZoneIds": {
            "value": "[parameters('privateDnsZoneIds')]"
          },
          "tags": {
            "value": "[parameters('tags')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.45.15.27210",
              "templateHash": "9524211413905157884"
            }
          },
          "parameters": {
            "name": {
              "type": "string",
              "metadata": {
                "description": "Private endpoint name."
              }
            },
            "location": {
              "type": "string",
              "defaultValue": "[resourceGroup().location]",
              "metadata": {
                "description": "Azure location."
              }
            },
            "targetResourceId": {
              "type": "string",
              "metadata": {
                "description": "Resource ID of the target service (e.g. storage account, cosmos, cognitive account)."
              }
            },
            "subresourceNames": {
              "type": "array",
              "metadata": {
                "description": "List of subresource / groupId names to connect (e.g. [\"blob\"], [\"account\"], [\"Sql\"])."
              }
            },
            "subnetId": {
              "type": "string",
              "metadata": {
                "description": "Resource ID of the subnet where the PE NIC lives."
              }
            },
            "privateDnsZoneIds": {
              "type": "array",
              "metadata": {
                "description": "List of private DNS zone resource IDs that the PE registers its A record(s) in."
              }
            },
            "dnsZoneGroupName": {
              "type": "string",
              "defaultValue": "default",
              "metadata": {
                "description": "Optional. Custom name for the DNS zone group. Defaults to `default`."
              }
            },
            "tags": {
              "type": "object",
              "defaultValue": {},
              "metadata": {
                "description": "Tags applied to the PE."
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.Network/privateEndpoints",
              "apiVersion": "2024-05-01",
              "name": "[parameters('name')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "properties": {
                "subnet": {
                  "id": "[parameters('subnetId')]"
                },
                "privateLinkServiceConnections": [
                  {
                    "name": "[format('{0}-conn', parameters('name'))]",
                    "properties": {
                      "privateLinkServiceId": "[parameters('targetResourceId')]",
                      "groupIds": "[parameters('subresourceNames')]"
                    }
                  }
                ]
              }
            },
            {
              "condition": "[not(empty(parameters('privateDnsZoneIds')))]",
              "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
              "apiVersion": "2024-05-01",
              "name": "[format('{0}/{1}', parameters('name'), parameters('dnsZoneGroupName'))]",
              "properties": {
                "copy": [
                  {
                    "name": "privateDnsZoneConfigs",
                    "count": "[length(parameters('privateDnsZoneIds'))]",
                    "input": {
                      "name": "[format('config-{0}', copyIndex('privateDnsZoneConfigs'))]",
                      "properties": {
                        "privateDnsZoneId": "[parameters('privateDnsZoneIds')[copyIndex('privateDnsZoneConfigs')]]"
                      }
                    }
                  }
                ]
              },
              "dependsOn": [
                "[resourceId('Microsoft.Network/privateEndpoints', parameters('name'))]"
              ]
            }
          ],
          "outputs": {
            "id": {
              "type": "string",
              "value": "[resourceId('Microsoft.Network/privateEndpoints', parameters('name'))]"
            },
            "name": {
              "type": "string",
              "value": "[parameters('name')]"
            }
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Search/searchServices', variables('searchName'))]"
      ]
    }
  ],
  "outputs": {
    "id": {
      "type": "string",
      "value": "[resourceId('Microsoft.Search/searchServices', variables('searchName'))]"
    },
    "name": {
      "type": "string",
      "value": "[variables('searchName')]"
    },
    "endpoint": {
      "type": "string",
      "value": "[format('https://{0}.search.windows.net', variables('searchName'))]"
    },
    "principalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Search/searchServices', variables('searchName')), '2024-06-01-preview', 'full').identity.principalId]"
    }
  }
}