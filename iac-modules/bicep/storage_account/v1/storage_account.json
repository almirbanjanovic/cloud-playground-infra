      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "[format('{0}_{1}', parameters('accountTier'), parameters('replicationType'))]"
      },
      "kind": "StorageV2",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "minimumTlsVersion": "[parameters('minTlsVersion')]",
        "supportsHttpsTrafficOnly": true,
        "allowBlobPublicAccess": false,
        "allowSharedKeyAccess": false,
        "defaultToOAuthAuthentication": true,
        "publicNetworkAccess": "[if(parameters('publicNetworkAccessEnabled'), 'Enabled', 'Disabled')]",
        "networkAcls": {
          "copy": [
            {
              "name": "ipRules",
              "count": "[length(parameters('allowedIps'))]",
              "input": {
                "value": "[parameters('allowedIps')[copyIndex('ipRules')]]",
                "action": "Allow"
              }
            }
          ],
          "bypass": "AzureServices",
          "defaultAction": "[parameters('networkRulesDefaultAction')]",
          "virtualNetworkRules": []
        }
      }
    },
