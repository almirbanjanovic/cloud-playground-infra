        },
        "containerDeleteRetentionPolicy": {
          "enabled": true,
          "days": 30
        },
        "isVersioningEnabled": true,
        "lastAccessTimeTrackingPolicy": {
          "enable": true,
          "name": "AccessTimeTracking",
          "trackingGranularityInDays": 1
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('accountName'))]"
      ]
    },
