    }
  },
  "parameters": {
    "baseName": {
      "type": "string",
      "defaultValue": "ai-foundry",
      "metadata": {
        "description": "Short project identifier used as a prefix for derived names."
      }
    },
    "environment": {
      "type": "string",
      "defaultValue": "dev",
      "metadata": {
        "description": "Environment suffix (e.g. dev / prod)."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "westus3",
      "metadata": {
        "description": "Azure region for the VNet + every regional resource. `westus3` is on Microsoft's list of Foundry Agent Service regions that support the private-networking Standard Setup, has 3 availability zones, and has broad Azure OpenAI model coverage."
      }
    },
    "vnetName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "VNet name. Leave blank to use the convention vnet-<baseName>-<environment>-<location>."
      }
    },
    "vnetAddressSpace": {
      "type": "array",
      "defaultValue": [
        "10.0.0.0/16"
      ],
      "metadata": {
        "description": "VNet address space CIDR blocks."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "environment": "dev",
        "workload": "ai-foundry",
        "stack": "base",
        "managed_by": "bicep"
      },
      "metadata": {
        "description": "Tags applied to every resource."
      }
    }
  },
  "variables": {
    "effectiveVnetName": "[if(empty(parameters('vnetName')), format('vnet-{0}-{1}-{2}', parameters('baseName'), parameters('environment'), parameters('location')), parameters('vnetName'))]",
    "cognitiveDnsZones": [
      "privatelink.cognitiveservices.azure.com",
      "privatelink.openai.azure.com",
      "privatelink.services.ai.azure.com"
    ],
    "storageDnsZones": [
      "[format('privatelink.blob.{0}', environment().suffixes.storage)]",
      "[format('privatelink.file.{0}', environment().suffixes.storage)]",
      "[format('privatelink.queue.{0}', environment().suffixes.storage)]",
      "[format('privatelink.table.{0}', environment().suffixes.storage)]",
      "[format('privatelink.dfs.{0}', environment().suffixes.storage)]",
      "[format('privatelink.web.{0}', environment().suffixes.storage)]"
    ],
    "cosmosDnsZone": "privatelink.documents.azure.com",
    "searchDnsZone": "privatelink.search.windows.net",
    "subnets": {
      "cognitive_pep": {
        "name": "[format('snet-cognitive-{0}-{1}', parameters('baseName'), parameters('environment'))]",
        "addressPrefixes": [
          "10.0.1.0/24"
        ]
      },
      "storage_pep": {
        "name": "[format('snet-storage-{0}-{1}', parameters('baseName'), parameters('environment'))]",
        "addressPrefixes": [
          "10.0.2.0/24"
        ]
      },
      "cosmos_pep": {
        "name": "[format('snet-cosmos-{0}-{1}', parameters('baseName'), parameters('environment'))]",
        "addressPrefixes": [
          "10.0.3.0/24"
        ]
      },
      "search_pep": {
        "name": "[format('snet-search-{0}-{1}', parameters('baseName'), parameters('environment'))]",
        "addressPrefixes": [
          "10.0.4.0/24"
        ]
      },
      "agent": {
        "name": "[format('snet-agent-{0}-{1}', parameters('baseName'), parameters('environment'))]",
        "addressPrefixes": [
          "10.0.10.0/24"
        ],
        "delegations": [
          {
            "name": "Microsoft.App/environments",
            "properties": {
              "serviceName": "Microsoft.App/environments"
            }
          }
        ]
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "deploy-vnet",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "name": {
            "value": "[variables('effectiveVnetName')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "addressSpace": {
            "value": "[parameters('vnetAddressSpace')]"
          },
          "subnets": {
            "value": "[variables('subnets')]"
          },
          "tags": {
            "value": "[parameters('tags')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.45.15.27210",
              "templateHash": "6882147717753316509"
            }
          },
          "parameters": {
            "name": {
              "type": "string",
              "metadata": {
                "description": "VNet name."
              }
            },
            "location": {
              "type": "string",
              "defaultValue": "[resourceGroup().location]",
              "metadata": {
                "description": "Azure location for the VNet."
              }
            },
            "addressSpace": {
              "type": "array",
              "metadata": {
                "description": "Address space CIDR blocks for the VNet."
              }
            },
            "subnets": {
              "type": "object",
              "metadata": {
                "description": "Map of logical subnet key -> subnet definition."
              }
            },
            "tags": {
              "type": "object",
              "defaultValue": {},
              "metadata": {
                "description": "Tags applied to the VNet."
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.Network/virtualNetworks",
              "apiVersion": "2024-05-01",
              "name": "[parameters('name')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "properties": {
                "addressSpace": {
                  "addressPrefixes": "[parameters('addressSpace')]"
                }
              }
            },
            {
              "copy": {
                "name": "subnet",
                "count": "[length(items(parameters('subnets')))]",
                "mode": "serial",
                "batchSize": 1
              },
              "type": "Microsoft.Network/virtualNetworks/subnets",
              "apiVersion": "2024-05-01",
              "name": "[format('{0}/{1}', parameters('name'), items(parameters('subnets'))[copyIndex()].value.name)]",
              "properties": {
                "addressPrefixes": "[items(parameters('subnets'))[copyIndex()].value.addressPrefixes]",
                "delegations": "[coalesce(tryGet(items(parameters('subnets'))[copyIndex()].value, 'delegations'), createArray())]",
                "privateEndpointNetworkPolicies": "Disabled"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Network/virtualNetworks', parameters('name'))]"
              ]
            }
          ],
          "outputs": {
            "id": {
              "type": "string",
              "value": "[resourceId('Microsoft.Network/virtualNetworks', parameters('name'))]"
            },
            "name": {
              "type": "string",
              "value": "[parameters('name')]"
            },
            "subnetIds": {
              "type": "object",
              "value": "[toObject(items(parameters('subnets')), lambda('k', lambdaVariables('k').key), lambda('k', resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('name'), lambdaVariables('k').value.name)))]"
            },
            "subnetNames": {
              "type": "object",
              "value": "[toObject(items(parameters('subnets')), lambda('k', lambdaVariables('k').key), lambda('k', lambdaVariables('k').value.name))]"
            }
          }
        }
      }
    },
    {
