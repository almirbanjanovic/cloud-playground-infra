# Every variable in variables.tf has a working default, so you can just run
# `terraform apply` with no `-var` flags and get a working deploy of the
# networking / platform stack into `rg-ai-foundry-network-dev-westus3` in
# `westus3` (the CAF landing-zone-style RG for base). The peer workload stack
# deploys into its own RG (`rg-ai-foundry-workload-dev-westus3`) and looks
# base resources up cross-RG.
#
# Copy this file to `terraform.tfvars` and uncomment lines only if you want
# to override defaults. `terraform.tfvars` is git-ignored.

# --- Optional: override the networking RG (must exist before apply) ---
# resource_group_name = "rg-ai-foundry-network-dev-westus3"

# --- Optional: naming (must match workload/terraform/terraform.tfvars if overridden) ---
# base_name   = "ai-foundry"
# environment = "dev"
# location    = "westus3"     # see variables.tf for the list of supported Foundry regions
